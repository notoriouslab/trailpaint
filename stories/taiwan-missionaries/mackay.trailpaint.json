{
  "version": 2,
  "name": "馬偕博士台灣宣教足跡 1872-1901",
  "center": [25.05, 121.3],
  "zoom": 9,
  "spots": [
    {
      "id": "s1",
      "latlng": [25.1753, 121.4332],
      "num": 1,
      "title": "淡水（宣教基地）",
      "desc": "1872年3月9日抵達。建立偕醫館（北台灣第一間西式醫院, 1880）、牛津學堂（Oxford College, 1882）、淡水禮拜堂。終生以此為家，葬於淡水外僑墓園。",
      "photo": null,
      "iconId": "info",
      "cardOffset": { "x": 90, "y": -60 }
    },
    {
      "id": "s2",
      "latlng": [25.0836, 121.437],
      "num": 2,
      "title": "五股坑",
      "desc": "1872-1873年。抵台後最早設立的佈道所之一，從淡水步行前往傳教的第一站。",
      "photo": null,
      "iconId": "pin",
      "cardOffset": { "x": -110, "y": -50 }
    },
    {
      "id": "s3",
      "latlng": [25.0726, 121.5157],
      "num": 3,
      "title": "大龍峒",
      "desc": "1870-1880年代。設立大龍峒教會，也是馬偕公開拔牙傳教的地點之一（一生拔了超過兩萬一千顆牙）。",
      "photo": null,
      "iconId": "firstaid",
      "cardOffset": { "x": 90, "y": -40 }
    },
    {
      "id": "s4",
      "latlng": [25.034, 121.4997],
      "num": 4,
      "title": "艋舺（萬華）",
      "desc": "1873-1880年代。當時北台灣最繁華的聚落，馬偕在此遭遇激烈反對——被丟石頭、潑穢物，仍堅持設立教會。",
      "photo": null,
      "iconId": "warning",
      "cardOffset": { "x": -110, "y": -55 }
    },
    {
      "id": "s5",
      "latlng": [24.9677, 121.5419],
      "num": 5,
      "title": "新店",
      "desc": "1870-1880年代。沿新店溪深入山區接觸平埔族群（凱達格蘭族），設立教會作為進入山地的據點。",
      "photo": null,
      "iconId": "tree",
      "cardOffset": { "x": 90, "y": -50 }
    },
    {
      "id": "s6",
      "latlng": [24.9556, 121.2257],
      "num": 6,
      "title": "中壢",
      "desc": "1870-1880年代。淡水到新竹巡迴傳教路線上的中繼站，設有教會。",
      "photo": null,
      "iconId": "pin",
      "cardOffset": { "x": -100, "y": -45 }
    },
    {
      "id": "s7",
      "latlng": [24.8015, 120.9686],
      "num": 7,
      "title": "竹塹（新竹）",
      "desc": "1873-1890年代。馬偕宣教範圍的最南端，與南部英國長老教會（台南）的勢力範圍交界。",
      "photo": null,
      "iconId": "pin",
      "cardOffset": { "x": -110, "y": -60 }
    },
    {
      "id": "s8",
      "latlng": [25.1276, 121.7392],
      "num": 8,
      "title": "基隆",
      "desc": "1873-1890年代。重要港口城市，設有教會。1884年清法戰爭期間法軍砲轟基隆，民眾遷怒基督徒，多間教會被毀，戰後馬偕重建七座教堂。",
      "photo": null,
      "iconId": "water",
      "cardOffset": { "x": 90, "y": -50 }
    },
    {
      "id": "s9",
      "latlng": [25.091, 121.856],
      "num": 9,
      "title": "三貂角",
      "desc": "1880年代。東北角海岸線上的傳教路線，步行翻越山嶺前往宜蘭的必經之路，沿途在漁村、礦村佈道。",
      "photo": null,
      "iconId": "rock",
      "cardOffset": { "x": 90, "y": -40 }
    },
    {
      "id": "s10",
      "latlng": [24.757, 121.753],
      "num": 10,
      "title": "噶瑪蘭（宜蘭）",
      "desc": "1883-1890年代。馬偕最成功的宣教區之一，噶瑪蘭族與平埔族比漢人更接受福音，在蘭陽平原設立超過20個佈道所。",
      "photo": null,
      "iconId": "flower",
      "cardOffset": { "x": -110, "y": -55 }
    },
    {
      "id": "s11",
      "latlng": [24.5964, 121.857],
      "num": 11,
      "title": "蘇澳",
      "desc": "1880-1890年代。宜蘭平原東南端的港口，前往東海岸的出發點，馬偕在此接觸更多原住民族群。",
      "photo": null,
      "iconId": "water",
      "cardOffset": { "x": 90, "y": -50 }
    },
    {
      "id": "s12",
      "latlng": [23.9769, 121.6044],
      "num": 12,
      "title": "花蓮（奇萊）",
      "desc": "1880-1890年代。馬偕翻山越嶺或走海路抵達東海岸，探訪原住民部落，是宣教足跡的最遠點。",
      "photo": null,
      "iconId": "sun",
      "cardOffset": { "x": -110, "y": -50 }
    }
  ],
